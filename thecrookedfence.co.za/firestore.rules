rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    function isBootstrapAdmin() {
      let email = isSignedIn() &&
                  request.auth.token.email != null
        ? request.auth.token.email.lower()
        : null;

      return email == 'bradsgbaker14@gmail.com' ||
             email == 'admin@thecrookedfence.co.za' ||
             email == 'stolschristopher60@gmail.com' ||
             email == 'bradley@binarybaker.co.za';
    }

    function roleFromUserDoc() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function roleFromToken() {
      return isSignedIn() && request.auth.token.role != null
        ? request.auth.token.role
        : null;
    }

    function requesterRole() {
      let docRole = roleFromUserDoc();
      return !isSignedIn()
        ? null
        : (
            isBootstrapAdmin()
              ? 'admin'
              : (
                  docRole != null
                    ? docRole
                    : roleFromToken()
                )
          );
    }

    function isSuperAdmin() { return requesterRole() == 'super_admin'; }
    function isAdmin() { let r = requesterRole(); return r == 'admin' || r == 'super_admin'; }
    function isWorker() { return requesterRole() == 'worker'; }
    function hasAssigneeAccess(data) {
      return isSignedIn() &&
        data.assigneeIds is list &&
        request.auth.uid in data.assigneeIds;
    }

    function isValidOrderPhone(value) {
      return value is string &&
        value.matches('^(\\+\\d{1,4}\\s+)?(\\d{9}|0\\d{9})$');
    }

    // ------------------------------
    // Orders
    // ------------------------------
    match /eggOrders/{docId} {
      // Public creates are handled by callable functions only.
      allow create: if isAdmin() || isWorker();
      allow read: if true;
      allow update, delete: if isAdmin() || isWorker();
    }

    match /financeEntries/{entryId} {
      allow read, create, delete: if request.auth != null;
      allow update: if false;
    }

    match /livestockOrders/{docId} {
      // Public creates are handled by callable functions only.
      allow create: if isAdmin() || isWorker();
      allow read: if true;
      allow update, delete: if isAdmin() || isWorker();
    }

    match /orderDrafts/{docId} {
      // Public draft reads/writes are handled by callable functions.
      allow read, create, update, delete: if isAdmin() || isWorker();
    }

    match /orderIdempotency/{docId} {
      allow read, create, update, delete: if isAdmin() || isWorker();
    }

    match /eggCategories/{docId} {
      // Open read so the public egg form can load categories
      allow read: if true;
      // Allow any signed-in user; UI restricts to admins
      allow create, update, delete: if request.auth != null;
    }

    match /eggTypes/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /deliveryOptions/{docId} {
      allow read: if true;
      // Allow any authenticated user; UI restricts to admins
      allow create, update, delete: if request.auth != null;
    }

    match /livestockDeliveryOptions/{docId} {
      allow read: if true;
      // Allow any authenticated user; UI restricts to admins
      allow create, update, delete: if request.auth != null;
    }

    // ------------------------------
    // Users
    // ------------------------------
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null &&
        (
          isSuperAdmin() ||
          (
            isAdmin() &&
            request.resource.data.role != 'super_admin' &&
            resource.data.role != 'super_admin'
          )
        );
    }

    // ------------------------------
    // Stock
    // ------------------------------
    match /stockCategories/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Allow any signed-in user to update (e.g., add subcategories)
      allow update: if request.auth != null;
      // Any signed-in user can delete a category
      allow delete: if request.auth != null;
    }

    match /stockItems/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Allow any authenticated user to delete/update items (UI enforces who can delete)
      allow delete: if request.auth != null;
      allow update: if request.auth != null;
    }

    match /stockLogs/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete, update: if false;
    }

    // Stock update submissions (history/logbook)
    match /stockUpdateLogs/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ------------------------------
    // Feed
    // ------------------------------
    match /feedCategories/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && (isAdmin() || isSuperAdmin());
    }

    match /feedLogs/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete, update: if false;
    }

    // ------------------------------
    // Egg Collection
    // ------------------------------
    match /eggCollectCategories/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && (isAdmin() || isSuperAdmin());
    }

    match /eggCollectLogs/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete, update: if false;
    }

    // ------------------------------
    // Livestock
    // ------------------------------
    match /livestockCategories/{docId} {
      // Open read so the public livestock form can load categories
      allow read: if true;
      // Allow any signed-in user; UI restricts to admins
      allow create, update, delete: if request.auth != null;
    }

    match /livestockTypes/{docId} {
      // Open read so the public livestock form can load types
      allow read: if true;
      // Allow any signed-in user; UI restricts to admins
      allow create, update, delete: if request.auth != null;
    }

    match /typeImageLibrary/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // ------------------------------
    // Chicks
    // ------------------------------
    match /chickCategories/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && (isAdmin() || isSuperAdmin());
    }

    match /chickLogs/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete, update: if false;
    }

    // ------------------------------
    // Deaths
    // ------------------------------
    match /deathCategories/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && (isAdmin() || isSuperAdmin());
    }

    match /deathLogs/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete, update: if false;
    }

    // ------------------------------
    // Operations Planner
    // ------------------------------
    match /operationsTaskCategories/{docId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /operationsEventCategories/{docId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /operationsTasks/{docId} {
      allow read: if isAdmin() || hasAssigneeAccess(resource.data);
      allow create, update, delete: if isAdmin();
    }

    match /operationsEvents/{docId} {
      allow read: if isAdmin() || hasAssigneeAccess(resource.data);
      allow create, update, delete: if isAdmin();
    }

    match /operationsTaskOccurrences/{docId} {
      allow read: if isAdmin() || hasAssigneeAccess(resource.data);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        (
          isWorker() &&
          hasAssigneeAccess(resource.data) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'progressNote',
            'completedAt',
            'completedByUid',
            'updatedAt',
            'updatedByUid'
          ])
        );
    }

    match /operationsEventOccurrences/{docId} {
      allow read: if isAdmin() || hasAssigneeAccess(resource.data);
      allow create, update, delete: if isAdmin();
    }

    match /operationsNotifications/{docId} {
      allow read: if isAdmin() ||
        (
          isSignedIn() &&
          resource.data.userId == request.auth.uid
        );
      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'read',
          'readAt'
        ]);
      allow create, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
