rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isBootstrapAdmin() {
      return isSignedIn() &&
          request.auth.token.email != null &&
        (
          request.auth.token.email.lower() == "bradsgbaker14@gmail.com" ||
          request.auth.token.email.lower() == "admin@thecrookedfence.co.za" ||
          request.auth.token.email.lower() == "stolschristopher60@gmail.com" ||
          request.auth.token.email.lower() == "bradley@binarybaker.co.za"
        );
    }

    function isAdmin() {
      return isSignedIn() &&
        (
          request.auth.token.role == "admin" ||
          request.auth.token.role == "super_admin" ||
          isBootstrapAdmin()
        );
    }

    function isWorker() {
      return isSignedIn() && request.auth.token.role == "worker";
    }

    match /orders/{collection}/{orderId}/{fileName} {
      allow read, write: if isAdmin() || isWorker();
    }

    match /finance/{fileName} {
      allow read, write: if isAdmin();
    }

    match /stock_updates/{userId}/{fileName} {
      allow write: if isSignedIn() && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    match /types/{typeGroup}/{typeId}/{fileName} {
      allow read: if true;
      allow write: if (isAdmin() || isWorker()) && (typeGroup == "egg" || typeGroup == "livestock");
    }

    match /type-library/{assetId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin() || isWorker();
    }

    match /operations/tasks/{taskId}/{fileName} {
      allow read, write: if isAdmin();
    }

    match /operations/events/{eventId}/{fileName} {
      allow read, write: if isAdmin();
    }
  }
}
